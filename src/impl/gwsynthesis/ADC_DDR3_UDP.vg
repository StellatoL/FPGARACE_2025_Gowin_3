`pragma protect end_protected
module fifo_uart (
  uart_rx_done_Z,
  clk_12_5M,
  clk_200M,
  uart_rx_packet_Z,
  DataNUM,
  uart_wave,
  uart_frequency,
  w_data,
  w_ad,
  Frequence,
  my_order
)
;
input uart_rx_done_Z;
input clk_12_5M;
input clk_200M;
input [107:0] uart_rx_packet_Z;
output [31:0] DataNUM;
output [2:0] uart_wave;
output [2:0] uart_frequency;
output [7:0] w_data;
output [8:0] w_ad;
output [31:0] Frequence;
output [7:0] my_order;
wire VCC;
wire GND;
  \~fifo.fifo_uart  fifo_inst (
    .uart_rx_done_Z(uart_rx_done_Z),
    .clk_12_5M(clk_12_5M),
    .clk_200M(clk_200M),
    .uart_rx_packet_Z(uart_rx_packet_Z[107:0]),
    .DataNUM(DataNUM[31:0]),
    .uart_wave(uart_wave[2:0]),
    .uart_frequency(uart_frequency[2:0]),
    .w_data(w_data[7:0]),
    .w_ad(w_ad[8:0]),
    .Frequence(Frequence[31:0]),
    .my_order(my_order[7:0])
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
endmodule /* fifo_uart */
module control (
  uart_rx_done_Z,
  clk_12_5M,
  clk_200M,
  uart_rx_packet_Z,
  DataNUM,
  uart_wave,
  uart_frequency,
  w_data,
  w_ad,
  Frequence,
  my_order
)
;
input uart_rx_done_Z;
input clk_12_5M;
input clk_200M;
input [107:0] uart_rx_packet_Z;
output [31:0] DataNUM;
output [2:0] uart_wave;
output [2:0] uart_frequency;
output [7:0] w_data;
output [8:0] w_ad;
output [31:0] Frequence;
output [7:0] my_order;
wire VCC;
wire GND;
  fifo_uart fifo_uart (
    .uart_rx_done_Z(uart_rx_done_Z),
    .clk_12_5M(clk_12_5M),
    .clk_200M(clk_200M),
    .uart_rx_packet_Z(uart_rx_packet_Z[107:0]),
    .DataNUM(DataNUM[31:0]),
    .uart_wave(uart_wave[2:0]),
    .uart_frequency(uart_frequency[2:0]),
    .w_data(w_data[7:0]),
    .w_ad(w_ad[8:0]),
    .Frequence(Frequence[31:0]),
    .my_order(my_order[7:0])
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
endmodule /* control */
