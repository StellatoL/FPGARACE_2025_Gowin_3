`pragma protect end_protected
module rd_data_fifo (
  Data,
  Reset,
  WrClk,
  RdClk,
  WrEn,
  RdEn,
  Wnum,
  Rnum,
  Almost_Empty,
  Almost_Full,
  Q,
  Empty,
  Full
)
;
input [127:0] Data;
input Reset;
input WrClk;
input RdClk;
input WrEn;
input RdEn;
output [9:0] Wnum;
output [12:0] Rnum;
output Almost_Empty;
output Almost_Full;
output [15:0] Q;
output Empty;
output Full;
wire VCC;
wire GND;
  \~fifo.rd_data_fifo  fifo_inst (
    .Reset(Reset),
    .RdClk(RdClk),
    .WrClk(WrClk),
    .WrEn(WrEn),
    .RdEn(RdEn),
    .Data(Data[127:0]),
    .Empty(Empty),
    .Full(Full),
    .Almost_Empty(Almost_Empty),
    .Almost_Full(Almost_Full),
    .Wnum(Wnum[9:0]),
    .Rnum(Rnum[12:0]),
    .Q(Q[15:0])
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
  GSR GSR (
    .GSRI(VCC) 
);
endmodule /* rd_data_fifo */
