`pragma protect end_protected
module fifo_uart (
  Data,
  WrClk,
  RdClk,
  WrEn,
  RdEn,
  Q,
  Empty,
  Full
)
;
input [199:0] Data;
input WrClk;
input RdClk;
input WrEn;
input RdEn;
output [199:0] Q;
output Empty;
output Full;
wire VCC;
wire GND;
  \~fifo.fifo_uart  fifo_inst (
    .RdClk(RdClk),
    .WrClk(WrClk),
    .WrEn(WrEn),
    .RdEn(RdEn),
    .Data(Data[199:0]),
    .Full(Full),
    .Empty(Empty),
    .Q(Q[199:0])
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
  GSR GSR (
    .GSRI(VCC) 
);
endmodule /* fifo_uart */
