module Gowin_rPLL (
  clk_d,
  n193_6,
  PLL_200M
)
;
input clk_d;
input n193_6;
output PLL_200M;
wire clkoutp_o;
wire clkoutd_o;
wire clkoutd3_o;
wire lock_o;
wire VCC;
wire GND;
  rPLL rpll_inst (
    .CLKOUT(PLL_200M),
    .CLKOUTP(clkoutp_o),
    .CLKOUTD(clkoutd_o),
    .CLKOUTD3(clkoutd3_o),
    .LOCK(lock_o),
    .CLKIN(clk_d),
    .CLKFB(GND),
    .FBDSEL({GND,GND,GND,GND,GND,GND}),
    .IDSEL({GND,GND,GND,GND,GND,GND}),
    .ODSEL({GND,GND,GND,GND,GND,GND}),
    .DUTYDA({GND,GND,GND,GND}),
    .PSDA({GND,GND,GND,GND}),
    .FDLY({GND,GND,GND,GND}),
    .RESET(n193_6),
    .RESET_P(GND) 
);
defparam rpll_inst.CLKFB_SEL="internal";
defparam rpll_inst.CLKOUTD3_SRC="CLKOUT";
defparam rpll_inst.CLKOUTD_BYPASS="false";
defparam rpll_inst.CLKOUTD_SRC="CLKOUT";
defparam rpll_inst.CLKOUTP_BYPASS="false";
defparam rpll_inst.CLKOUTP_DLY_STEP=0;
defparam rpll_inst.CLKOUTP_FT_DIR=1'b1;
defparam rpll_inst.CLKOUT_BYPASS="false";
defparam rpll_inst.CLKOUT_DLY_STEP=0;
defparam rpll_inst.CLKOUT_FT_DIR=1'b1;
defparam rpll_inst.DEVICE="GW2A-18C";
defparam rpll_inst.DUTYDA_SEL="1000";
defparam rpll_inst.DYN_DA_EN="false";
defparam rpll_inst.DYN_FBDIV_SEL="false";
defparam rpll_inst.DYN_IDIV_SEL="false";
defparam rpll_inst.DYN_ODIV_SEL="false";
defparam rpll_inst.DYN_SDIV_SEL=2;
defparam rpll_inst.FBDIV_SEL=3;
defparam rpll_inst.FCLKIN="50";
defparam rpll_inst.IDIV_SEL=0;
defparam rpll_inst.ODIV_SEL=4;
defparam rpll_inst.PSDA_SEL="0000";
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
endmodule /* Gowin_rPLL */
module top (
  clk,
  rst_n,
  extern_clk,
  uart_txd
)
;
input clk;
input rst_n;
input extern_clk;
output uart_txd;
wire clk_d;
wire rst_n_d;
wire extern_clk_d;
wire n193_6;
wire uart_txd_d;
wire extern_done;
wire PLL_200M;
wire [31:0] extern_freq;
wire VCC;
wire GND;
  IBUF clk_ibuf (
    .O(clk_d),
    .I(clk) 
);
  IBUF rst_n_ibuf (
    .O(rst_n_d),
    .I(rst_n) 
);
  IBUF extern_clk_ibuf (
    .O(extern_clk_d),
    .I(extern_clk) 
);
  OBUF uart_txd_obuf (
    .O(uart_txd),
    .I(uart_txd_d) 
);
  INV n193_s2 (
    .O(n193_6),
    .I(rst_n_d) 
);
  uart_data_tx uart_data_tx_inst (
    .clk_d(clk_d),
    .n193_6(n193_6),
    .extern_done(extern_done),
    .rst_n_d(rst_n_d),
    .extern_freq(extern_freq[31:0]),
    .uart_txd_d(uart_txd_d)
);
  cymometer_equal cymometer_equal_inst (
    .extern_clk_d(extern_clk_d),
    .n193_6(n193_6),
    .PLL_200M(PLL_200M),
    .extern_done(extern_done),
    .extern_freq(extern_freq[31:0])
);
  Gowin_rPLL Gowin_rPLL_inst (
    .clk_d(clk_d),
    .n193_6(n193_6),
    .PLL_200M(PLL_200M)
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
  GSR GSR (
    .GSRI(VCC) 
);
endmodule /* top */
