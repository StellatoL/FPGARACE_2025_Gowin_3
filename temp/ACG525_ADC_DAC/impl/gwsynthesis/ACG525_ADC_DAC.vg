  fifo_empty,
  fifo_full,
  fifo_almost_full,
  ADC_fifo
)
;
input n6_6;
input n142_9;
input n66_6;
input clk_200M;
input ADC_clk_d;
output fifo_empty;
output fifo_full;
output fifo_almost_full;
output [7:0] ADC_fifo;
wire VCC;
wire GND;
  \~fifo.fifo_top  fifo_inst (
    .n6_6(n6_6),
    .n142_9(n142_9),
    .n66_6(n66_6),
    .clk_200M(clk_200M),
    .ADC_clk_d(ADC_clk_d),
    .fifo_empty(fifo_empty),
    .fifo_full(fifo_full),
    .fifo_almost_full(fifo_almost_full),
    .ADC_fifo(ADC_fifo[7:0])
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
endmodule /* fifo_top */
