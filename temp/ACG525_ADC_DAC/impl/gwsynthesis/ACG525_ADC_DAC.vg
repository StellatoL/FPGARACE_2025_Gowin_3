    .I1(GND),
    .I3(GND),
    .CIN(n20_2) 
);
defparam n19_s.ALU_MODE=0;
  ALU n18_s (
    .SUM(n18_1),
    .COUT(n18_2),
    .I0(phase_accumulator[21]),
    .I1(GND),
    .I3(GND),
    .CIN(n19_2) 
);
defparam n18_s.ALU_MODE=0;
  ALU n17_s (
    .SUM(n17_1),
    .COUT(n17_2),
    .I0(phase_accumulator[22]),
    .I1(GND),
    .I3(GND),
    .CIN(n18_2) 
);
defparam n17_s.ALU_MODE=0;
  ALU n16_s (
    .SUM(n16_1),
    .COUT(n16_0_COUT),
    .I0(phase_accumulator[23]),
    .I1(GND),
    .I3(GND),
    .CIN(n17_2) 
);
defparam n16_s.ALU_MODE=0;
  INV n6_s2 (
    .O(n6_6),
    .I(rLockOut) 
);
  INV n38_s2 (
    .O(n38_6),
    .I(phase_accumulator[1]) 
);
  wave_ram wave_ram (
    .DAC_clk_d(DAC_clk_d),
    .n6_6(n6_6),
    .phase_accumulator(phase_accumulator[23:16])
);
  sine sine_rom (
    .DAC_clk_d(DAC_clk_d),
    .n6_6(n6_6),
    .phase_accumulator(phase_accumulator[23:16])
);
  square square_rom (
    .DAC_clk_d(DAC_clk_d),
    .n6_6(n6_6),
    .phase_accumulator(phase_accumulator[23:16])
);
  triangular triangular_rom (
    .DAC_clk_d(DAC_clk_d),
    .n6_6(n6_6),
    .phase_accumulator(phase_accumulator[23:16]),
    .triangular(triangular[7:0])
);
  sawtooth sawtooth_rom (
    .DAC_clk_d(DAC_clk_d),
    .n6_6(n6_6),
    .phase_accumulator(phase_accumulator[23:16])
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
endmodule /* DDS */
module ACM108_DAC (
  DAC_clk_d,
  rLockOut,
  DAC_data_d
)
;
input DAC_clk_d;
input rLockOut;
output [7:0] DAC_data_d;
wire VCC;
wire GND;
  DDS DDS (
    .DAC_clk_d(DAC_clk_d),
    .rLockOut(rLockOut),
    .DAC_data_d(DAC_data_d[7:0])
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
endmodule /* ACM108_DAC */
module ACG525_TOP (
  clk_50M,
  reset,
  ADC_data,
  DAC_data,
  ADC_clk,
  DAC_clk,
  uart_tx,
  uart_led
)
;
input clk_50M;
input reset;
input [7:0] ADC_data;
output [7:0] DAC_data;
output ADC_clk;
output DAC_clk;
output uart_tx;
output uart_led;
wire clk_50M_d;
wire reset_d;
wire clk_200M;
wire DAC_clk_d;
wire ADC_clk_d;
wire rLockOut;
wire n66_6;
wire uart_tx_d;
wire uart_led_d;
wire [7:0] DAC_data_d;
wire VCC;
wire GND;
  IBUF clk_50M_ibuf (
    .O(clk_50M_d),
    .I(clk_50M) 
);
  IBUF reset_ibuf (
    .O(reset_d),
    .I(reset) 
);
  OBUF DAC_data_0_obuf (
    .O(DAC_data[0]),
    .I(DAC_data_d[0]) 
);
  OBUF DAC_data_1_obuf (
    .O(DAC_data[1]),
    .I(DAC_data_d[1]) 
);
  OBUF DAC_data_2_obuf (
    .O(DAC_data[2]),
    .I(DAC_data_d[2]) 
);
  OBUF DAC_data_3_obuf (
    .O(DAC_data[3]),
    .I(DAC_data_d[3]) 
);
  OBUF DAC_data_4_obuf (
    .O(DAC_data[4]),
    .I(DAC_data_d[4]) 
);
  OBUF DAC_data_5_obuf (
    .O(DAC_data[5]),
    .I(DAC_data_d[5]) 
);
  OBUF DAC_data_6_obuf (
    .O(DAC_data[6]),
    .I(DAC_data_d[6]) 
);
  OBUF DAC_data_7_obuf (
    .O(DAC_data[7]),
    .I(DAC_data_d[7]) 
);
  OBUF ADC_clk_obuf (
    .O(ADC_clk),
    .I(ADC_clk_d) 
);
  OBUF DAC_clk_obuf (
    .O(DAC_clk),
    .I(DAC_clk_d) 
);
  OBUF uart_tx_obuf (
    .O(uart_tx),
    .I(uart_tx_d) 
);
  OBUF uart_led_obuf (
    .O(uart_led),
    .I(uart_led_d) 
);
  Gowin_PLL Gowin_PLL (
    .clk_50M_d(clk_50M_d),
    .n66_6(n66_6),
    .clk_200M(clk_200M),
    .DAC_clk_d(DAC_clk_d),
    .ADC_clk_d(ADC_clk_d),
    .rLockOut(rLockOut)
);
  ACM108_ADC ACM108_ADC (
    .clk_200M(clk_200M),
    .reset_d(reset_d),
    .ADC_clk_d(ADC_clk_d),
    .n66_6(n66_6),
    .uart_tx_d(uart_tx_d),
    .uart_led_d(uart_led_d)
);
  ACM108_DAC ACM108_DAC (
    .DAC_clk_d(DAC_clk_d),
    .rLockOut(rLockOut),
    .DAC_data_d(DAC_data_d[7:0])
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
  GSR GSR (
    .GSRI(VCC) 
);
endmodule /* ACG525_TOP */
