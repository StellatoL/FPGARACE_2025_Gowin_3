`pragma protect end_protected
module fifo_top (
  Data,
  Reset,
  WrClk,
  RdClk,
  WrEn,
  RdEn,
  AlmostFullSetTh,
  AlmostFullClrTh,
  Almost_Empty,
  Almost_Full,
  Q,
  Empty,
  Full
)
;
input [7:0] Data;
input Reset;
input WrClk;
input RdClk;
input WrEn;
input RdEn;
input [7:0] AlmostFullSetTh;
input [7:0] AlmostFullClrTh;
output Almost_Empty;
output Almost_Full;
output [7:0] Q;
output Empty;
output Full;
wire VCC;
wire GND;
  \~fifo.fifo_top  fifo_inst (
    .Reset(Reset),
    .RdClk(RdClk),
    .WrClk(WrClk),
    .WrEn(WrEn),
    .RdEn(RdEn),
    .Data(Data[7:0]),
    .AlmostFullClrTh(AlmostFullClrTh[7:0]),
    .AlmostFullSetTh(AlmostFullSetTh[7:0]),
    .Empty(Empty),
    .Full(Full),
    .Almost_Empty(Almost_Empty),
    .Almost_Full(Almost_Full),
    .Q(Q[7:0])
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
  GSR GSR (
    .GSRI(VCC) 
);
endmodule /* fifo_top */
