module ACG525_top (
  clk,
  rst_n,
  uart_txd,
  uart_rxd,
  uart_txd2,
  scl,
  sda,
  spi_cs,
  spi_clk,
  spi_mosi,
  spi_miso,
  PWM,
  can_rxd,
  can_txd,
  extern_clk
)
;
input clk;
input rst_n;
output uart_txd;
input uart_rxd;
output uart_txd2;
output scl;
inout sda;
output spi_cs;
output spi_clk;
output spi_mosi;
input spi_miso;
output [3:0] PWM;
input can_rxd;
output can_txd;
input extern_clk;
wire clk_d;
wire rst_n_d;
wire uart_rxd_d;
wire spi_miso_d;
wire can_rxd_d;
wire extern_clk_d;
wire sda_in;
wire n9_8;
wire uart_txd2_d;
wire uart_txd_d;
wire scl_d;
wire sda_out;
wire sda_6;
wire spi_mosi_d;
wire spi_cs_d;
wire spi_clk_d;
wire can_txd_d;
wire extern_done;
wire [0:0] PWM_d;
wire [1:1] PWM_d_7;
wire [2:2] PWM_d_8;
wire [3:3] PWM_d_9;
wire [31:0] extern_freq;
wire [9:0] extern_duty;
wire VCC;
wire GND;
  IBUF clk_ibuf (
    .O(clk_d),
    .I(clk) 
);
  IBUF rst_n_ibuf (
    .O(rst_n_d),
    .I(rst_n) 
);
  IBUF uart_rxd_ibuf (
    .O(uart_rxd_d),
    .I(uart_rxd) 
);
  IBUF spi_miso_ibuf (
    .O(spi_miso_d),
    .I(spi_miso) 
);
  IBUF can_rxd_ibuf (
    .O(can_rxd_d),
    .I(can_rxd) 
);
  IBUF extern_clk_ibuf (
    .O(extern_clk_d),
    .I(extern_clk) 
);
  IOBUF sda_iobuf (
    .O(sda_in),
    .IO(sda),
    .I(sda_out),
    .OEN(sda_6) 
);
  OBUF uart_txd_obuf (
    .O(uart_txd),
    .I(uart_txd_d) 
);
  OBUF uart_txd2_obuf (
    .O(uart_txd2),
    .I(uart_txd2_d) 
);
  OBUF scl_obuf (
    .O(scl),
    .I(scl_d) 
);
  OBUF spi_cs_obuf (
    .O(spi_cs),
    .I(spi_cs_d) 
);
  OBUF spi_clk_obuf (
    .O(spi_clk),
    .I(spi_clk_d) 
);
  OBUF spi_mosi_obuf (
    .O(spi_mosi),
    .I(spi_mosi_d) 
);
  OBUF PWM_0_obuf (
    .O(PWM[0]),
    .I(PWM_d[0]) 
);
  OBUF PWM_1_obuf (
    .O(PWM[1]),
    .I(PWM_d_7[1]) 
);
  OBUF PWM_2_obuf (
    .O(PWM[2]),
    .I(PWM_d_8[2]) 
);
  OBUF PWM_3_obuf (
    .O(PWM[3]),
    .I(PWM_d_9[3]) 
);
  OBUF can_txd_obuf (
    .O(can_txd),
    .I(can_txd_d) 
);
  uart_data_tx uart_data_tx_inst2 (
    .clk_d(clk_d),
    .extern_done(extern_done),
    .rst_n_d(rst_n_d),
    .extern_freq(extern_freq[31:0]),
    .extern_duty(extern_duty[9:0]),
    .n9_8(n9_8),
    .uart_txd2_d(uart_txd2_d)
);
  uart uart_inst (
    .clk_d(clk_d),
    .n9_8(n9_8),
    .rst_n_d(rst_n_d),
    .uart_rxd_d(uart_rxd_d),
    .sda_in(sda_in),
    .spi_miso_d(spi_miso_d),
    .can_rxd_d(can_rxd_d),
    .uart_txd_d(uart_txd_d),
    .scl_d(scl_d),
    .sda_out(sda_out),
    .sda_6(sda_6),
    .spi_mosi_d(spi_mosi_d),
    .spi_cs_d(spi_cs_d),
    .spi_clk_d(spi_clk_d),
    .can_txd_d(can_txd_d),
    .PWM_d(PWM_d[0]),
    .PWM_d_4(PWM_d_7[1]),
    .PWM_d_5(PWM_d_8[2]),
    .PWM_d_6(PWM_d_9[3])
);
  digital_measure digital_measure_top_inst (
    .clk_d(clk_d),
    .n9_8(n9_8),
    .extern_clk_d(extern_clk_d),
    .rst_n_d(rst_n_d),
    .extern_done(extern_done),
    .extern_freq(extern_freq[31:0]),
    .extern_duty(extern_duty[9:0])
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
  GSR GSR (
    .GSRI(VCC) 
);
endmodule /* ACG525_top */
